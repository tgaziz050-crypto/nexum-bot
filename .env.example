# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
WEBAPP_URL=https://your-app.up.railway.app
ADMIN_IDS=123456789

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=./data/nexum.db
NODE_PORT=3000

# ── Public bot (allow all users) ──────────────────────────────────────────────
PUBLIC_BOT=true

# ── AI Providers (round-robin, up to 10 keys each) ────────────────────────────
# Cerebras (fastest — Llama 3.3 70B)
CB1=
CB2=
CB3=

# Groq (fast — Llama 3.3 70B + Whisper STT)
GR1=
GR2=
GR3=

# Google Gemini (vision capable)
G1=
G2=
G3=

# Grok (xAI)
GK1=
GK2=

# SambaNova
SN1=
SN2=

# Together AI
TO1=
TO2=

# OpenRouter
OR1=
OR2=

# DeepSeek
DS1=
DS2=

# Anthropic Claude
CL1=
CL2=

# ── Web Search ─────────────────────────────────────────────────────────────────
SERPER_KEY=
SERPER_KEY2=
SERPER_KEY3=

# ── TTS (edge-tts CLI must be installed) ──────────────────────────────────────
# EDGE_TTS_PATH=edge-tts
# EDGE_PYTHON_PATH=/opt/edge-tts-env/bin/python3
