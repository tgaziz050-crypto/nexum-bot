# ── TTS — Голос ───────────────────────────────────────────────────────────────
# Edge-TTS (Microsoft Neural) — БЕСПЛАТНО, встроен в Docker
# Никаких ключей не нужно! 400+ голосов, 50+ языков без акцента
# Голоса: ru-RU-SvetlanaNeural, en-US-AriaNeural, uz-UZ-MadinaNeural, ...

# Режим голоса по умолчанию:
# auto   = голос → голос (как ChatGPT), текст → текст
# always = всегда отвечать голосом
# never  = только текст
VOICE_MODE=auto
