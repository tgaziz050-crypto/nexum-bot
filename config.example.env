# ╔══════════════════════════════════════════════════════╗
# ║     NEXUM — Конфигурация                            ║
# ║  Скопируй в .env и вставь свои ключи               ║
# ║  НИКОГДА не коммить .env в GitHub!                  ║
# ╚══════════════════════════════════════════════════════╝

# ══════════════════════════════════════
#  TELEGRAM BOT TOKEN (обязательно!)
#  Создать бота: t.me/BotFather → /newbot
# ══════════════════════════════════════
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ══════════════════════════════════════
#  GEMINI KEYS — aistudio.google.com
#  Бесплатно, до 10 ключей для ротации
# ══════════════════════════════════════
G1=YOUR_GEMINI_KEY_1
G2=YOUR_GEMINI_KEY_2
G3=YOUR_GEMINI_KEY_3
G4=YOUR_GEMINI_KEY_4
G5=YOUR_GEMINI_KEY_5
G6=YOUR_GEMINI_KEY_6
G7=YOUR_GEMINI_KEY_7
G8=
G9=
G10=

# ══════════════════════════════════════
