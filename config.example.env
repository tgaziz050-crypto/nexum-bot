# NEXUM v7.0 — Конфигурация
# Скопируй этот файл в .env и заполни значения

# ═══════════════════ ОБЯЗАТЕЛЬНО ═══════════════════
BOT_TOKEN=your_telegram_bot_token_here

# ═══════════════════ AI КЛЮЧИ (опционально) ═══════════════════
# Google Gemini (бесплатно: aistudio.google.com)
G1=your_gemini_key_1
G2=your_gemini_key_2
G3=your_gemini_key_3

# Groq (бесплатно: console.groq.com)
GR1=your_groq_key_1
GR2=your_groq_key_2
GR3=your_groq_key_3

# DeepSeek (дешёвый: platform.deepseek.com)
DS1=your_deepseek_key_1

# Claude / Anthropic
CL1=your_claude_key

# Grok / xAI
GK1=your_grok_key

# ═══════════════════ СЕРВИСЫ ═══════════════════
# Распознавание музыки (audd.io)
AUDD_API_KEY=your_audd_key

# ACRCloud (acrcloud.com) — альтернатива AudD
ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
ACRCLOUD_KEY=your_acrcloud_key
ACRCLOUD_SECRET=your_acrcloud_secret

# ═══════════════════ EMAIL ═══════════════════
# Gmail пример:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password  (не основной пароль, а App Password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
