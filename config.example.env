# NEXUM v1.0 — Пример конфигурации
# Скопируй в .env и заполни значения. НЕ КОММИТЬ .env на GitHub!

# ═══════════════════════════════════════════════════
#  ОБЯЗАТЕЛЬНО
# ═══════════════════════════════════════════════════
BOT_TOKEN=your_telegram_bot_token_here

# ═══════════════════════════════════════════════════
#  AI КЛЮЧИ — нужен хотя бы один провайдер
# ═══════════════════════════════════════════════════

# Google Gemini — бесплатно: aistudio.google.com
# Можно добавить до 8 ключей для round-robin ротации
G1=your_gemini_key_1
G2=your_gemini_key_2
G3=your_gemini_key_3
G4=
G5=
G6=
G7=
G8=
# Или один список через запятую:
# GEMINI_KEYS=key1,key2,key3

# Groq — бесплатно: console.groq.com (быстрый, Whisper STT)
GR1=your_groq_key_1
GR2=your_groq_key_2
GR3=

# DeepSeek — дёшево: platform.deepseek.com
DS1=your_deepseek_key
DS2=

# Anthropic Claude
CL1=your_claude_key
CL2=

# xAI Grok
GK1=your_grok_key
GK2=

# ═══════════════════════════════════════════════════
#  МЕДИАГЕНЕРАЦИЯ
# ═══════════════════════════════════════════════════

# HuggingFace — бесплатно: huggingface.co/settings/tokens
# Нужен для MusicGen, ZeroScope (видео), Bark (вокал)
HF_TOKEN=your_huggingface_token

# Replicate — платно, для AnimateDiff видео (опционально)
REPLICATE_API_TOKEN=your_replicate_token

# ═══════════════════════════════════════════════════
#  NOTION (опционально)
# ═══════════════════════════════════════════════════
# Токен интеграции: notion.so/my-integrations
NOTION_TOKEN=secret_your_notion_integration_token
# ID страницы по умолчанию (из URL страницы Notion)
NOTION_DEFAULT_PAGE=your_notion_page_id

# ═══════════════════════════════════════════════════
#  EMAIL (опционально)
# ═══════════════════════════════════════════════════
# Gmail: используй App Password (не основной пароль)
# myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ═══════════════════════════════════════════════════
#  РАСПОЗНАВАНИЕ МУЗЫКИ (опционально)
# ═══════════════════════════════════════════════════
AUDD_API_KEY=your_audd_key
ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
ACRCLOUD_KEY=your_acrcloud_key
ACRCLOUD_SECRET=your_acrcloud_secret
