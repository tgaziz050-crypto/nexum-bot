# ══════════════════════════════════════
#  ПОИСКОВЫЕ ДВИЖКИ (необязательно)
# ══════════════════════════════════════

# Serper.dev — Google Search API
# Бесплатно: 2500 запросов/месяц — serper.dev
SERPER_KEY=
SERPER_KEY2=
SERPER_KEY3=

# Brave Search — search.brave.com/api
# Бесплатно: 2000 запросов/месяц
BRAVE_KEY=
BRAVE_KEY2=
BRAVE_KEY3=

# ══════════════════════════════════════
#  ДОПОЛНИТЕЛЬНЫЕ (необязательно)
# ══════════════════════════════════════

# HuggingFace — для генерации музыки
# huggingface.co/settings/tokens
HF_TOKEN=

# AudD — распознавание музыки
# audd.io
AUDD_KEY=

# Notion интеграция
# notion.so/my-integrations
NOTION_TOKEN=
NOTION_DEFAULT_PAGE=

# Email (Gmail App Password)
# myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# GitHub — для self-modify (необязательно)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
BOT_FILENAME=bot.py
