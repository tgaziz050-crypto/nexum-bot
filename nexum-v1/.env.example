# ══════════════════════════════════════════════════════
#  NEXUM v1 — Railway Variables
#  Этот файл идёт в GitHub. Реальные ключи — ТОЛЬКО в Railway.
# ══════════════════════════════════════════════════════

# Telegram
BOT_TOKEN=

# Твой Telegram ID (владелец бота — получает особые права)
ADMIN_IDS=

# true = бот открыт для всех, false = только ADMIN_IDS
PUBLIC_BOT=true

# База данных
DB_PATH=./nexum.db

# WebSocket порт для PC агента
NODE_PORT=18790

# ── AI Провайдеры (добавь хотя бы 1) ─────────────────

