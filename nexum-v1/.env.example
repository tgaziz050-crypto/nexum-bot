GR2=
GR3=
GR4=
GR5=

# Gemini — aistudio.google.com (бесплатно)
G1=
G2=
G3=
G4=
G5=

# Grok xAI — console.x.ai
GK1=
GK2=
GK3=

# SambaNova — cloud.sambanova.ai (бесплатно)
