{
  "name": "nexum",
  "version": "1.0.0",
  "description": "NEXUM v1 — Multi-user AI platform for Telegram",
  "type": "module",
  "scripts": {
    "dev":       "tsx watch src/index.ts",
    "build":     "tsc",
    "start":     "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "grammy":              "^1.30.0",
    "@grammyjs/runner":   "^2.0.3",
    "better-sqlite3":     "^9.6.0",
    "dotenv":             "^16.4.5",
    "winston":            "^3.13.0",
    "node-cron":          "^3.0.3",
    "node-fetch":         "^3.3.2",
    "form-data":          "^4.0.0",
    "ws":                 "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node":           "^22.0.0",
    "@types/node-cron":      "^3.0.11",
    "@types/ws":             "^8.5.12",
    "tsx":                   "^4.19.0",
    "typescript":            "^5.5.0"
  },
  "engines": { "node": ">=20" }
}
