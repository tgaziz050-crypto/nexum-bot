{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022"],
    "outDir":            "./dist",
    "strict":            true,
    "skipLibCheck":      true,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "declaration":       true,
    "sourceMap":         true
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}
