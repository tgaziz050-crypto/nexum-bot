{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "node",
    "lib":               ["ES2022", "DOM"],
    "outDir":            "./dist",
    "strict":            false,
    "skipLibCheck":      true,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "declaration":       true,
    "sourceMap":         true,
    "allowSyntheticDefaultImports": true
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}
