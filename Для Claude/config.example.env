# NEXUM — скопируй в .env и заполни
# .env не попадает в git

BOT_TOKEN=your_telegram_bot_token

# API ключи (опционально, можно оставить в bot.py)
G1=
G2=
GR1=
GR2=
DS1=
DS2=
CL1=
GK1=

# Распознавание музыки (AudD — бесплатный tier)
AUDD_API_KEY=

# Email (для отправки писем с разрешения пользователя)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
